{
  "name": "ai-plugin-app",
  "version": "1.0.1",
  "description": "AI插件桌面应用",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:build:win": "vite build && electron-builder --win"
  },
  "dependencies": {
    "@langchain/core": "^1.1.42",
    "@langchain/openai": "^1.4.5",
    "electron-updater": "^6.1.8",
    "langchain": "^1.3.5",
    "openai": "^6.34.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^8.2.2",
    "electron": "^28.1.0",
    "electron-builder": "^24.9.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.aiplugin.app",
    "productName": "AI插件应用",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "CWtongxin",
      "repo": "ai-assistant-app",
      "releaseType": "release"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "AI插件应用"
    }
  }
}
